# ------------------------------------------------------------------
# Variables de entorno — network-learning-game
# Copia este archivo a `.env` (ya está en .gitignore) y completa los
# valores reales. NUNCA commitees `.env` ni pegues secretos en el chat.
# ------------------------------------------------------------------

# Entorno de ejecución
NODE_ENV=development

# --- Supabase (Postgres + Auth) ---------------------------------
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreto de servidor — NUNCA exponer al cliente/frontend
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / PostgreSQL ------------------------------------------
# Dashboard: Project Settings → Database → Connection string
# DATABASE_URL: conexión pooled (pgbouncer, puerto 6543) — usada en runtime por Prisma Client
DATABASE_URL=
# DIRECT_URL: conexión directa (puerto 5432) — usada solo por `prisma migrate`
DIRECT_URL=

# --- API (NestJS) ---------------------------------------------------
API_PORT=3001
# Usado para firmar/verificar tokens propios de la API si aplica (además de Supabase Auth)
JWT_SECRET=

# --- Frontend (Next.js) ---------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
