# ------------------------------------------------------------------
# Variables de entorno — network-learning-game
# Copia este archivo a `.env` (ya está en .gitignore) y completa los
# valores reales. NUNCA commitees `.env` ni pegues secretos en el chat.
# ------------------------------------------------------------------

# Entorno de ejecución
NODE_ENV=development

# --- Supabase (Postgres + Auth) ---------------------------------
# Dashboard: Project Settings → API
# NEXT_PUBLIC_SUPABASE_URL también la usa apps/backend para construir la URL
# del JWKS público (.../auth/v1/.well-known/jwks.json) con el que verifica
# los access tokens de Supabase Auth — este proyecto los firma con ES256
# (clave asimétrica), no con un secreto compartido. Ver DECISIONS.md.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secreto de servidor — NUNCA exponer al cliente/frontend. Lo usan los tests
# e2e de apps/backend para crear/eliminar usuarios reales de prueba vía la
# Admin API (cero mocks: los tests obtienen tokens ES256 genuinos con un
# login real, no los fabrican).
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / PostgreSQL ------------------------------------------
# Dashboard: Project Settings → Database → Connection string
# DATABASE_URL: conexión pooled (pgbouncer, puerto 6543) — usada en runtime por Prisma Client
DATABASE_URL=
# DIRECT_URL: conexión directa (puerto 5432) — usada solo por `prisma migrate`
DIRECT_URL=

# --- API (NestJS) ---------------------------------------------------
API_PORT=3001

# --- Frontend (Next.js) ---------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
